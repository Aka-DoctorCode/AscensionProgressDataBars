package-as: AscensionBars
license-output: LICENSE
enable-nolib-creation: no

ignore:
    - __MACOSX
    - pkgmeta.yaml

externals:
  Libs/LibStub:
    url: https://github.com/Stanzilla/LibStub
  Libs/CallbackHandler-1.0:
    url: https://github.com/WoWUIDev/CallbackHandler
  Libs/Ace3:
    url: https://github.com/WoWUIDev/Ace3

manual-changelog: 
    filename: CHANGELOG.txt
    markup-type: html